@page
@model OnlineBookstore.Pages.LoginModel

<div class="login-page">
    <div class="login-card">
        <h1>Welcome Back</h1>
        <p class="login-subtitle">Log in to continue shopping</p>

        <form method="post">
            <div class="form-group">
                <label>Email</label>
                <input asp-for="Email" class="form-control" placeholder="Enter your email" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" />
            </div>

            <button type="submit" class="btn btn-primary w-100 mt-3">Login</button>
        </form>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <p class="login-message">@Model.Message</p>
        }

        <p class="signup-link">
            Need an account?
            <a asp-page="/SignUp">Sign up</a>
        </p>
    </div>
</div>