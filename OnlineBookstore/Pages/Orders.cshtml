@page
@model OnlineBookstore.Pages.OrdersModel
@{
    ViewData["Title"] = "Order History";
}

<h1>Order History</h1>

@if (!Model.Orders.Any())
{
    <p>You have not placed any orders yet.</p>
}
else
{
    @foreach (var order in Model.Orders)
    {
        <div class="card mb-4">
            <div class="card-header">
                <strong>Order #@order.OrderID</strong> |
                @order.OrderDate.ToString("M/d/yyyy h:mm tt")
            </div>
            <div class="card-body">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Book</th>
                            <th>Quantity</th>
                            <th>Unit Price</th>
                            <th>Total</th>
                            <th>Rate</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in order.Items)
                        {
                            <tr>
                                <td>@item.Title</td>
                                <td>@item.Quantity</td>
                                <td>$@item.UnitPrice</td>
                                <td>$@(item.Quantity* item.UnitPrice)</td>
                                <td>
                                    <form method="post" asp-page-handler="RateBook">
                                        <input type="hidden" name="bookId" value="@item.BookID" />

                                        <select name="score" class="form-select form-select-sm d-inline w-auto">
                                            <option value="5">5 ⭐</option>
                                            <option value="4">4 ⭐</option>
                                            <option value="3">3 ⭐</option>
                                            <option value="2">2 ⭐</option>
                                            <option value="1">1 ⭐</option>
                                        </select>

                                        <button type="submit" class="btn btn-sm btn-primary">Rate</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <h5>Order Total: $@order.Total</h5>
            </div>
        </div>
    }
}