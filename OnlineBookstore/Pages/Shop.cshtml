@page
@model PrivacyModel
@{
    ViewData["Title"] = "Books";
}
<h1>@ViewData["Title"]</h1>

<div class="book-list">
    @foreach (Book b in ViewData["Books"] as List<Book>)
    {
        <div class="book-box">
            @if (!string.IsNullOrEmpty(b.ImagePath))
            {
                <img class="book-image" src="@b.ImagePath" alt="@b.Title" width="120" />
            }
            <div class="book-details">
                <h4>@b.Title</h4>
                <h6>@b.AuthorName</h6>
                <p class="book-price">$@b.Price</p>
                <form method="post" asp-page-handler="AddToCart">
                    <input type="hidden" name="bookId" value="@b.ID" />
                    <button type="submit" class="add-btn">Add</button>
                </form>
                <p>⭐ @b.AverageRating.ToString("0.0") / 5 (@b.RatingCount)</p>
            </div>
        </div>
    }
</div>
